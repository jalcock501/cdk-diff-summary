    "SampleApp-Prod-AuditStack": {
      "templatePath": "cdk.out/SampleApp-Prod-AuditStack.template.json",
      "changeSet": [
        {
          "id": "AuditBucket",
          "path": "SampleApp-Prod-AuditStack/AuditBucket/Resource",
          "changeType": "Modify",
          "logicalId": "AuditBucket2C95B9B2",
          "resourceType": "AWS::S3::Bucket",
          "replacement": "False",
          "changeImpact": "Switches bucket encryption to KMS and adds lifecycle transition",
          "before": {
            "BucketEncryption": {
              "ServerSideEncryptionConfiguration": [
                {
                  "ServerSideEncryptionByDefault": {
                    "SSEAlgorithm": "AES256"
                  }
                }
              ]
            }
          },
          "after": {
            "BucketEncryption": {
              "ServerSideEncryptionConfiguration": [
                {
                  "ServerSideEncryptionByDefault": {
                    "SSEAlgorithm": "aws:kms",
                    "KMSMasterKeyID": {
                      "Fn::GetAtt": [
                        "AuditKey7A8BC0D0",
                        "Arn"
                      ]
                    }
                  }
                }
              ]
            },
            "LifecycleConfiguration": {
              "Rules": [
                {
                  "Status": "Enabled",
                  "Transitions": [
                    {
                      "StorageClass": "GLACIER",
                      "TransitionInDays": 90
                    }
                  ]
                }
              ]
            }
          }
        },
        {
          "id": "AuditKey",
          "path": "SampleApp-Prod-AuditStack/AuditKey/Resource",
          "changeType": "Add",
          "logicalId": "AuditKey7A8BC0D0",
          "resourceType": "AWS::KMS::Key",
          "replacement": "N/A",
          "changeImpact": "Adds customer-managed KMS key for audit bucket",
          "after": {
            "EnableKeyRotation": true,
            "KeyPolicy": {
              "Statement": [
                {
                  "Effect": "Allow",
                  "Principal": {
                    "AWS": {
                      "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:root"
                    }
                  },
                  "Action": "kms:*",
                  "Resource": "*"
                }
              ]
            }
          }
        },
        {
          "id": "AuditBucketPolicy",
          "path": "SampleApp-Prod-AuditStack/AuditBucketPolicy/Resource",
          "changeType": "Modify",
          "logicalId": "AuditBucketPolicyD4C8ED77",
          "resourceType": "AWS::S3::BucketPolicy",
          "replacement": "False",
          "changeImpact": "Denies insecure transport to audit bucket",
          "before": {
            "PolicyDocument": {
              "Statement": []
            }
          },
          "after": {
            "PolicyDocument": {
              "Statement": [
                {
                  "Sid": "DenyInsecureTransport",
                  "Effect": "Deny",
                  "Action": "s3:*",
                  "Principal": "*",
                  "Resource": [
                    {
                      "Fn::GetAtt": [
                        "AuditBucket2C95B9B2",
                        "Arn"
                      ]
                    },
                    {
                      "Fn::Join": [
                        "",
                        [
                          {
                            "Fn::GetAtt": [
                              "AuditBucket2C95B9B2",
                              "Arn"
                            ]
                          },
                          "/*"
                        ]
                      ]
                    }
                  ],
                  "Condition": {
                    "Bool": {
                      "aws:SecureTransport": "false"
                    }
                  }
                }
              ]
            }
          }
        }
      ],
      "securityChanges": {
        "hasSecurityChanges": true,
        "permissionsBroadening": [
          {
            "resource": "AuditKey7A8BC0D0",
            "reason": "Adds root account KMS admin policy"
          }
        ]
      }
    },
