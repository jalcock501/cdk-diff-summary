    "SampleApp-Prod-ServiceStack": {
      "templatePath": "cdk.out/SampleApp-Prod-ServiceStack.template.json",
      "changeSet": [
        {
          "id": "AppTaskDefinition",
          "path": "SampleApp-Prod-ServiceStack/AppTaskDefinition/Resource",
          "changeType": "Modify",
          "logicalId": "AppTaskDefinition2D5A72B1",
          "resourceType": "AWS::ECS::TaskDefinition",
          "replacement": "True",
          "changeImpact": "Replaces task definition with larger CPU/memory and telemetry sidecar",
          "before": {
            "Cpu": "512",
            "Memory": "1024",
            "ContainerDefinitions": [
              {
                "Name": "app",
                "Image": "app:1.8.2"
              }
            ]
          },
          "after": {
            "Cpu": "1024",
            "Memory": "2048",
            "ContainerDefinitions": [
              {
                "Name": "app",
                "Image": "app:1.9.0"
              },
              {
                "Name": "otel-agent",
                "Image": "public.ecr.aws/aws-observability/aws-otel-collector:v0.40.0"
              }
            ]
          }
        },
        {
          "id": "AppService",
          "path": "SampleApp-Prod-ServiceStack/AppService/Resource",
          "changeType": "Modify",
          "logicalId": "AppService7FA3E12E",
          "resourceType": "AWS::ECS::Service",
          "replacement": "False",
          "changeImpact": "Scales desired count and enables deployment circuit breaker",
          "before": {
            "DesiredCount": 2,
            "DeploymentConfiguration": {
              "MaximumPercent": 200,
              "MinimumHealthyPercent": 50
            }
          },
          "after": {
            "DesiredCount": 4,
            "DeploymentConfiguration": {
              "MaximumPercent": 200,
              "MinimumHealthyPercent": 100,
              "DeploymentCircuitBreaker": {
                "Enable": true,
                "Rollback": true
              }
            }
          }
        },
        {
          "id": "TaskExecutionRoleDefaultPolicy",
          "path": "SampleApp-Prod-ServiceStack/TaskExecutionRoleDefaultPolicy/Resource",
          "changeType": "Modify",
          "logicalId": "AppTaskExecutionRoleDefaultPolicyA88C3A71",
          "resourceType": "AWS::IAM::Policy",
          "replacement": "False",
          "changeImpact": "Adds Secrets Manager and X-Ray telemetry permissions",
          "before": {
            "PolicyDocument": {
              "Statement": [
                {
                  "Action": [
                    "ecr:GetAuthorizationToken",
                    "logs:CreateLogStream",
                    "logs:PutLogEvents"
                  ],
                  "Effect": "Allow",
                  "Resource": "*"
                }
              ]
            }
          },
          "after": {
            "PolicyDocument": {
              "Statement": [
                {
                  "Action": [
                    "ecr:GetAuthorizationToken",
                    "logs:CreateLogStream",
                    "logs:PutLogEvents"
                  ],
                  "Effect": "Allow",
                  "Resource": "*"
                },
                {
                  "Action": [
                    "secretsmanager:GetSecretValue"
                  ],
                  "Effect": "Allow",
                  "Resource": {
                    "Ref": "DatabaseSecret"
                  }
                },
                {
                  "Action": [
                    "xray:PutTraceSegments",
                    "xray:PutTelemetryRecords"
                  ],
                  "Effect": "Allow",
                  "Resource": "*"
                }
              ]
            }
          }
        }
      ],
      "securityChanges": {
        "hasSecurityChanges": true,
        "permissionsBroadening": [
          {
            "resource": "AppTaskExecutionRoleDefaultPolicyA88C3A71",
            "reason": "Adds secretsmanager:GetSecretValue and X-Ray write actions"
          }
